# Docker Compose Override File (Development)
# This file allows you to override settings from docker-compose.yml
# To use: docker-compose -f docker-compose.yml -f docker-compose.override.yml up

version: '3.8'

services:
  clickhouse:
    # Uncomment to use local data directory instead of volume
    # volumes:
    #   - ./clickhouse-data:/var/lib/clickhouse
    #   - ./clickhouse-logs:/var/log/clickhouse-server
    environment:
      # Enable debug logging in ClickHouse
      # CLICKHOUSE_LOG_LEVEL: debug
